# .env.example — copy to .env for local dev, or set vars in Docker/Swarm
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault folder.
# Windows (stdio): VAULT_PATH=C:\Users\DJ\Documents\Notes\Home
# Linux / Docker:  VAULT_PATH=/vault  (mount the vault volume here)
VAULT_PATH=

# ── Optional ──────────────────────────────────────────────────────────────────

# Human-readable vault name shown in MCP client descriptions.
VAULT_NAME=My Vault

# Transport mode: stdio (default, for Claude Desktop) or http (for Swarm/remote)
TRANSPORT=stdio

# HTTP port — only used when TRANSPORT=http
PORT=3000
